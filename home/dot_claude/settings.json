{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-wsl-tools.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-windows.sh"
          }
        ]
      }
    ]
  }
}
